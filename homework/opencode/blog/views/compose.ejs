<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>發布新文章 - 網誌</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    :root {
      --bg-primary: #fafafa;
      --bg-card: #ffffff;
      --border-color: #dbdbdb;
      --text-primary: #262626;
      --text-secondary: #8e8e8e;
      --accent: #0095f6;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
    }
    
    .container {
      max-width: 470px;
      margin: 0 auto;
      min-height: 100vh;
      background: var(--bg-card);
    }
    
    .header {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: var(--bg-card);
      z-index: 100;
    }
    
    .back-btn {
      color: var(--text-primary);
      font-size: 20px;
      text-decoration: none;
      padding: 8px;
    }
    
    .compose-btn {
      background: var(--accent);
      color: white;
      border: none;
      padding: 8px 20px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    
    .compose-btn:hover { opacity: 0.8; }
    
    .compose-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .compose-area {
      padding: 16px;
      display: flex;
      gap: 12px;
    }
    
    .avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 18px;
      color: white;
      flex-shrink: 0;
    }
    
    .compose-form {
      flex: 1;
    }
    
    .compose-form textarea {
      width: 100%;
      background: transparent;
      border: none;
      color: var(--text-primary);
      font-size: 16px;
      resize: none;
      min-height: 200px;
      outline: none;
      line-height: 1.5;
      font-family: inherit;
    }
    
    .compose-form textarea::placeholder {
      color: var(--text-secondary);
    }
    
    .divider {
      height: 1px;
      background: var(--border-color);
      margin: 0 16px;
    }
    
    .compose-options {
      padding: 8px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .icon-btn {
      color: var(--accent);
      font-size: 20px;
      padding: 8px;
      cursor: pointer;
      background: none;
      border: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="header">
      <a href="/" class="back-btn">✕</a>
      <button type="button" class="compose-btn" id="submitBtn" onclick="submitPost()">發布</button>
    </header>
    
    <form class="compose-area" id="mainForm">
      <div class="avatar" style="background: <%= ['#f97316','#22c55e','#3b82f6','#ec4899','#8b5cf6'][user.username.charCodeAt(0) % 5] %>">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
      <div class="compose-form">
        <textarea name="content" placeholder="有什麼新鮮事？" id="contentInput" required autofocus></textarea>
      </div>
    </form>
    
    <div class="divider"></div>
    
    <div class="compose-options">
      <button type="button" class="icon-btn" title="添加媒體">🖼️</button>
    </div>
  </div>
  
  <script>
    function submitPost() {
      const content = document.getElementById('contentInput').value;
      if (!content.trim()) return;
      
      fetch('/compose', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'content=' + encodeURIComponent(content)
      }).then(() => {
        window.location.href = '/';
      });
    }
  </script>
</body>
</html>
